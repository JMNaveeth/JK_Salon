# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE_PROJECT_ID: Firebase project for backend Firestore persistence.
FIREBASE_PROJECT_ID="jksalon-14783"

# FIREBASE_SERVICE_ACCOUNT_KEY: Optional JSON string for service account credentials.
# If omitted, backend will try GOOGLE_APPLICATION_CREDENTIALS/application default credentials.
# Example format: {"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_KEY=""

# FIREBASE_STORAGE_BUCKET: Bucket used by backend upload API for persistent media storage.
FIREBASE_STORAGE_BUCKET="jksalon-14783.firebasestorage.app"

# SQLITE_PATH: Optional local fallback path when Firestore is not configured.
SQLITE_PATH="./jksalon.db"
